<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover">
    <title>Spectra — Чтение</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Merriweather:wght@300;400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="styles.css">
</head>
<body data-theme="light" data-reading-theme="classic" data-font="inter" data-margins="normal" data-align="justify">

    <header class="reader-header">
        <button class="btn-icon" onclick="toggleBookmarkPanel()"><i class="fas fa-bookmark"></i></button>
        <div class="book-info">
            <span class="book-title-header">Название книги 1</span>
            <span class="book-chapter">Глава 1</span>
        </div>
        <div class="header-actions">
            <button class="btn-icon" onclick="toggleComments()">
                <i class="fas fa-comment"></i>
                <span id="commentCount">0</span>
            </button>
            <button class="btn-icon" onclick="toggleSettings()"><i class="fas fa-sliders-h"></i></button>
        </div>
    </header>

    <div class="reading-progress" id="progressContainer" onclick="jumpToPosition(event)">
        <div class="progress-bar" id="progressBar" style="width: 24%;"></div>
    </div>

    <div class="reader-container">
        <div class="reader-content">
            <div class="book-content" id="bookContent">
                <h1>Название книги 1</h1>
                <h2>Глава 1. Начало пути</h2>
                <p>Ветер тихо шелестел листвой старых кленов, растущих вдоль университетской аллеи. Алексей стоял у окна библиотеки и смотрел, как первые осенние листья медленно кружатся в воздухе...</p>
            </div>
        </div>
    </div>

    <div id="settingsPanel" class="settings-panel">
        <div class="settings-header">
            <h2>Настройки</h2>
            <button class="btn-icon" onclick="toggleSettings()"><i class="fas fa-times"></i></button>
        </div>
        <div class="settings-content">
            <div class="settings-section">
                <div class="settings-section-title"><i class="fas fa-text-height"></i> Вид текста</div>
                <div class="settings-row">
                    <span class="settings-label">Размер шрифта</span>
                    <input type="range" class="range-slider" id="fontSlider" min="12" max="42" value="18" oninput="changeFontSize(this.value)">
                    <span class="range-value" id="fontSizeVal">18px</span>
                </div>
                <div class="settings-row">
                    <span class="settings-label">Количество колонок</span>
                    <div class="settings-options">
                        <button class="settings-option active" id="btnCol1" onclick="setColumns(1)">1</button>
                        <button class="settings-option" id="btnCol2" onclick="setColumns(2)">2</button>
                    </div>
                </div>
                <div class="settings-row">
                    <span class="settings-label">Ширина текста</span>
                    <input type="range" class="range-slider" min="400" max="1200" value="800" oninput="changeContentWidth(this.value)">
                </div>
            </div>
            
            <div class="settings-section">
                <div class="settings-section-title"><i class="fas fa-font"></i> Шрифт</div>
                <div class="settings-options">
                    <button class="settings-option" onclick="setFont('inter')">Inter</button>
                    <button class="settings-option" onclick="setFont('merriweather')">Serif</button>
                </div>
            </div>

            <div class="theme-grid">
                <div class="theme-card" onclick="setReadingTheme('classic')">Классика</div>
                <div class="theme-card" onclick="setReadingTheme('night')">Ночь</div>
                <div class="theme-card" onclick="setReadingTheme('radiation')">Радиация</div>
            </div>
        </div>
    </div>

    <div id="bookmarkPanel" class="bookmark-panel">
        <div class="bookmark-header">
            <h3>Закладки</h3>
            <button class="btn-register" onclick="openBookmarkModal()"><i class="fas fa-plus"></i></button>
        </div>
        <div class="bookmark-list" id="bookmarkList"></div>
    </div>

    <div id="commentsPanel" class="comments-panel left-side">
        <div class="comments-header">
            <h3>Комментарии (<span id="commentsHeaderCount">0</span>)</h3>
            <button class="btn-icon" onclick="toggleComments()"><i class="fas fa-times"></i></button>
        </div>
        <div class="comment-input-group">
            <textarea id="commentInput" class="comment-input" placeholder="Введите текст..." maxlength="300" oninput="updateCharCount()"></textarea>
            <div style="display: flex; justify-content: space-between; margin-top: 10px;">
                <span id="charCounter" style="font-size: 12px; color: #888;">0 / 300</span>
                <button class="btn-send" onclick="addComment()"><i class="fas fa-paper-plane"></i></button>
            </div>
        </div>
        <div class="comments-list" id="commentsList"></div>
    </div>

    <div id="bookmarkModal" class="modal">
        <div class="modal-content">
            <h2 id="bmModalTitle">Добавить закладку</h2>
            <input type="hidden" id="editBookmarkId">
            <div style="margin-bottom: 15px;">
                <input type="text" id="bookmarkNameInput" class="comment-input" placeholder="Название закладки">
            </div>
            <div style="margin-bottom: 15px;">
                <input type="number" id="bookmarkPageInput" class="comment-input" placeholder="Номер страницы">
            </div>
            <div style="display: flex; gap: 10px;">
                <button class="btn-register" style="background: #eee; color: #000;" onclick="closeBookmarkModal()">Отмена</button>
                <button class="btn-register" onclick="saveBookmark()">Сохранить</button>
            </div>
        </div>
    </div>

    <div id="notification" class="notification">
        <span id="notificationMessage">Успешно</span>
    </div>

    <script src="script.js"></script>
</body>
</html>



/* Переменные из твоего исходника */
:root {
    --primary-h: 238;
    --primary-s: 83%;
    --primary-l: 67%;
    --primary: hsl(var(--primary-h), var(--primary-s), var(--primary-l));
    --bg: #faf7f2;
    --surface: hsla(0, 0%, 100%, 0.8);
    --text-primary: #2c3e50;
    --border-light: rgba(0,0,0,0.05);
    --header-height: 70px;
}

/* Темы */
body[data-reading-theme="night"] {
    background-color: #1a1e24;
    color: #b3c5d7;
}
body[data-reading-theme="night"] .reader-header {
    background-color: rgba(30, 35, 45, 0.8);
}

body[data-reading-theme="radiation"] {
    background-color: #0a0f0f;
    color: #a8ffc0;
}

/* Основные стили без сокращений */
body {
    margin-top: 0px;
    margin-right: 0px;
    margin-bottom: 0px;
    margin-left: 0px;
    padding-top: 0px;
    padding-right: 0px;
    padding-bottom: 0px;
    padding-left: 0px;
    font-family: 'Inter', sans-serif;
}

.reader-header {
    position: sticky;
    top: 0px;
    height: 70px;
    background-color: var(--surface);
    backdrop-filter: blur(15px);
    border-bottom-width: 1px;
    border-bottom-style: solid;
    border-bottom-color: var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-left: 20px;
    padding-right: 20px;
    z-index: 1000;
}

.reader-container {
    display: flex;
    justify-content: center;
    width: 100%;
}

.reader-content {
    width: 100%;
    max-width: 800px;
    padding-top: 40px;
    padding-bottom: 40px;
    padding-left: 20px;
    padding-right: 20px;
}

/* Панель комментариев слева */
.comments-panel {
    position: fixed;
    top: 70px;
    left: -400px;
    width: 350px;
    height: calc(100vh - 70px);
    background-color: var(--surface);
    backdrop-filter: blur(20px);
    border-right-width: 1px;
    border-right-style: solid;
    border-right-color: var(--border-light);
    transition-property: left;
    transition-duration: 0.4s;
    z-index: 1100;
    padding-top: 20px;
    padding-right: 20px;
    padding-bottom: 20px;
    padding-left: 20px;
}

.comments-panel.open {
    left: 0px;
}

/* Правые панели */
.settings-panel, .bookmark-panel {
    position: fixed;
    top: 70px;
    right: -400px;
    width: 350px;
    height: calc(100vh - 70px);
    background-color: var(--surface);
    backdrop-filter: blur(20px);
    border-left-width: 1px;
    border-left-style: solid;
    border-left-color: var(--border-light);
    transition-property: right;
    transition-duration: 0.4s;
    z-index: 1100;
    padding-top: 20px;
    padding-right: 20px;
    padding-bottom: 20px;
    padding-left: 20px;
}

.settings-panel.open, .bookmark-panel.open {
    right: 0px;
}

.btn-icon {
    width: 40px;
    height: 40px;
    border-radius: 20px;
    border-style: none;
    cursor: pointer;
}

.comment-input {
    width: 100%;
    border-width: 1px;
    border-style: solid;
    border-color: #dddddd;
    padding-top: 10px;
    padding-right: 10px;
    padding-bottom: 10px;
    padding-left: 10px;
    border-radius: 10px;
}

.modal {
    position: fixed;
    top: 0px;
    left: 0px;
    right: 0px;
    bottom: 0px;
    background-color: rgba(0, 0, 0, 0.5);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 2000;
}

.modal-content {
    background-color: #ffffff;
    padding-top: 25px;
    padding-right: 25px;
    padding-bottom: 25px;
    padding-left: 25px;
    border-radius: 15px;
    width: 350px;
}

var settingsOpen = false;
var bookmarkPanelOpen = false;
var commentsOpen = false;
var BANNED_WORDS = ['спам', 'реклама'];

function toggleSettings() {
    if (settingsOpen == false) {
        settingsOpen = true;
        document.getElementById('settingsPanel').classList.add('open');
        closeBookmarks();
        closeComments();
    } else {
        settingsOpen = false;
        document.getElementById('settingsPanel').classList.remove('open');
    }
}

function toggleBookmarkPanel() {
    if (bookmarkPanelOpen == false) {
        bookmarkPanelOpen = true;
        document.getElementById('bookmarkPanel').classList.add('open');
        closeSettings();
        closeComments();
    } else {
        bookmarkPanelOpen = false;
        document.getElementById('bookmarkPanel').classList.remove('open');
    }
}

function toggleComments() {
    if (commentsOpen == false) {
        commentsOpen = true;
        document.getElementById('commentsPanel').classList.add('open');
        closeSettings();
        closeBookmarks();
    } else {
        commentsOpen = false;
        document.getElementById('commentsPanel').classList.remove('open');
    }
}

function closeSettings() {
    settingsOpen = false;
    document.getElementById('settingsPanel').classList.remove('open');
}

function closeBookmarks() {
    bookmarkPanelOpen = false;
    document.getElementById('bookmarkPanel').classList.remove('open');
}

function closeComments() {
    commentsOpen = false;
    document.getElementById('commentsPanel').classList.remove('open');
}

function changeFontSize(size) {
    document.getElementById('fontSizeVal').innerHTML = size + 'px';
    document.getElementById('bookContent').style.fontSize = size + 'px';
}

function changeContentWidth(width) {
    document.querySelector('.reader-content').style.maxWidth = width + 'px';
}

function setColumns(count) {
    if (count == 1) {
        document.getElementById('bookContent').style.columnCount = "1";
        document.getElementById('btnCol1').classList.add('active');
        document.getElementById('btnCol2').classList.remove('active');
    } else {
        document.getElementById('bookContent').style.columnCount = "2";
        document.getElementById('bookContent').style.columnGap = "40px";
        document.getElementById('btnCol2').classList.add('active');
        document.getElementById('btnCol1').classList.remove('active');
    }
}

function updateCharCount() {
    var input = document.getElementById('commentInput');
    var text = input.value;
    
    // Прямая цензура ссылок
    text = text.replace("http://", "[ссылка]");
    text = text.replace("https://", "[ссылка]");
    
    // Прямая цензура слов
    for (var i = 0; i < BANNED_WORDS.length; i++) {
        var word = BANNED_WORDS[i];
        while (text.includes(word)) {
            text = text.replace(word, "***");
        }
    }
    
    input.value = text;
    document.getElementById('charCounter').innerHTML = text.length + " / 300";
}

function addComment() {
    var input = document.getElementById('commentInput');
    var text = input.value;
    if (text.length > 0) {
        var list = document.getElementById('commentsList');
        var item = document.createElement('div');
        item.className = 'comment-item';
        item.innerHTML = '<div style="font-weight: bold;">Вы</div><div>' + text + '</div>';
        list.insertBefore(item, list.firstChild);
        input.value = "";
        document.getElementById('commentCount').innerHTML = list.children.length;
        document.getElementById('commentsHeaderCount').innerHTML = list.children.length;
    }
}

function openBookmarkModal() {
    document.getElementById('bookmarkModal').style.display = 'flex';
}

function closeBookmarkModal() {
    document.getElementById('bookmarkModal').style.display = 'none';
    document.getElementById('editBookmarkId').value = "";
}

function saveBookmark() {
    var name = document.getElementById('bookmarkNameInput').value;
    var page = document.getElementById('bookmarkPageInput').value;
    var editId = document.getElementById('editBookmarkId').value;

    if (name == "") { name = "Закладка"; }
    if (page == "") { page = "1"; }

    if (editId != "") {
        var item = document.getElementById(editId);
        item.innerHTML = '<span>' + name + '</span> (стр. ' + page + ') <button onclick="editBookmark(\'' + editId + '\')" style="float: right;">ред.</button>';
    } else {
        var id = "bm_" + Date.now();
        var list = document.getElementById('bookmarkList');
        var div = document.createElement('div');
        div.className = 'bookmark-item';
        div.id = id;
        div.innerHTML = '<span>' + name + '</span> (стр. ' + page + ') <button onclick="editBookmark(\'' + id + '\')" style="float: right;">ред.</button>';
        list.insertBefore(div, list.firstChild);
    }
    closeBookmarkModal();
}

function editBookmark(id) {
    var item = document.getElementById(id);
    var content = item.getElementsByTagName('span')[0].innerHTML;
    document.getElementById('bookmarkNameInput').value = content;
    document.getElementById('editBookmarkId').value = id;
    openBookmarkModal();
}

function setReadingTheme(theme) {
    document.body.setAttribute('data-reading-theme', theme);
}

function setFont(font) {
    document.body.setAttribute('data-font', font);
}

function updateProgress(percent) {
    document.getElementById('progressBar').style.width = percent + '%';
}

function jumpToPosition(event) {
    var container = document.getElementById('progressContainer');
    var rect = container.getBoundingClientRect();
    var x = event.clientX - rect.left;
    var width = rect.width;
    var percent = (x / width) * 100;
    updateProgress(Math.round(percent));
}

document.onkeydown = function(e) {
    if (e.keyCode == 39) {
        console.log("Нажата стрелка вправо");
    }
    if (e.keyCode == 37) {
        console.log("Нажата стрелка влево");
    }
};



